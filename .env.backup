# ==========================================
# EALUMINI - Environment Variables
# Copie este arquivo para .env.local e preencha os valores
# ==========================================
#
# --- VERCEL (Production) — copie cada chave para Settings → Environment Variables ---
# Obrigatórias: DATABASE_URL, DIRECT_URL, NEXT_PUBLIC_SUPABASE_URL,
#   NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
#   JWT_SECRET, JWT_REFRESH_SECRET, NEXT_PUBLIC_APP_URL (URL pública do site, https://...)
# Opcionais: JWT_EXPIRES_IN, JWT_REFRESH_EXPIRES_IN, SMTP_*, EMAIL_FROM,
#   ULTRAMSG_INSTANCE_ID, ULTRAMSG_TOKEN, THERAPIST_WHATSAPP_NUMBER
# Não defina NODE_ENV manualmente na Vercel (a plataforma define).
# ==========================================

# --- DATABASE (Supabase) ---
# Acesse: https://app.supabase.com -> seu projeto -> Settings -> Database -> Connect
#
# DATABASE_URL (Vercel / serverless): Transaction pooler — IPv4 ok. Usuário = postgres.<REF> (com ponto).
# Copie a URI do painel (Method: Transaction) e substitua [YOUR-PASSWORD] pela senha real, SEM colchetos [].
# Acrescente na query string se ainda não vier: pgbouncer=true&connection_limit=1
# Exemplo:
# DATABASE_URL="postgresql://postgres.[REF]:SENHA@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL (migrations locais: prisma migrate deploy): conexão direta, usuário postgres (sem .ref)
# DIRECT_URL="postgresql://postgres:SENHA@db.[REF].supabase.co:5432/postgres?sslmode=require"
#
# A mesma senha do reset do banco nos dois. Caracteres especiais na senha: codifique na URL (%40 para @, etc.).
DATABASE_URL="postgresql://postgres.qcemykqrksvfyghwfvxd:EALumina2026@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.qcemykqrksvfyghwfvxd:EALumina2026@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# --- SUPABASE ---
# URL: projeto → Connect to project (ou Settings → General / API).
NEXT_PUBLIC_SUPABASE_URL="https://qcemykqrksvfyghwfvxd.supabase.co"
#
# ANON (cliente público / NEXT_PUBLIC_*):
# No modal "Connect", use a "Anon key (Legacy)" — JWT em 3 partes começando com eyJ...
# Evite colocar a "Publishable key" (sb_publishable_...) aqui: libs antigas podem falhar com "Invalid Compact JWS".
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFjZW15a3Fya3N2ZnlnaHdmdnhkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI5OTU3OTgsImV4cCI6MjA4ODU3MTc5OH0.NP4I6p2BUSbaC3piVTXzoBp0BGsVumFK6v9UjZkc8to"
#
# SERVICE ROLE (só servidor — upload Storage, supabaseAdmin):
# Settings → API → Secret keys (sb_secret_...) OU JWT "service_role" (Legacy), nunca a anon.
# Nunca commite este valor nem use em NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFjZW15a3Fya3N2ZnlnaHdmdnhkIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3Mjk5NTc5OCwiZXhwIjoyMDg4NTcxNzk4fQ.PG7e58Gm47PLky1jQxH5HfTGw31cdyteFmvIrkBKpHY"
# Obrigatório no painel: Storage → criar buckets com nomes exatos "documents" e "avatars" (senão: Bucket not found).

# --- JWT ---
# Gere com: openssl rand -base64 64
JWT_SECRET="wAHEhMicwz2cWbbgFN09nBZJ9q5PvMaAeBxVOiksTg3rYIA3QQ0cShKkWmlvZ2fXBsc3oiOa2MkmQoX9sJusGAQ=="
JWT_REFRESH_SECRET="RSp1dgOcUPRXkG7FR+ItgtZkZNbH3HLO4cs0BTkig2nSivNAKHcGl8Tw4keeDuPMDje0rCxjo5KMo"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- APP ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- EMAIL (Opcional - para recuperação de senha) ---
# Configure com Resend, SendGrid ou SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu@email.com"
SMTP_PASS="sua_senha_app"
EMAIL_FROM="EALumini <noreply@ealumini.com>"

# --- WHATSAPP (UltraMsg — https://ultramsg.com) ---
# Trial gratuito: 1.000 mensagens sem cartão.
# 1. Crie conta em ultramsg.com → nova instância → escaneie QR com o WhatsApp do terapeuta.
# 2. Copie Instance ID e Token do painel.
# THERAPIST_WHATSAPP_NUMBER: só dígitos, sem + (ex: 5511999999999)
ULTRAMSG_INSTANCE_ID="[SEU_INSTANCE_ID]"
ULTRAMSG_TOKEN="[SEU_TOKEN]"
THERAPIST_WHATSAPP_NUMBER="55XXXXXXXXXXX"

